#!/usr/bin/env bash
# provision-host: admin break-glass, fleet sudo audit, git/SSH, guard stack.
# See docs/specifications/SPEC-HOST-PROVISION.md
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"
# shellcheck source=scripts/lib/host-provision-state.sh
source "$LIB_DIR/host-provision-state.sh" || exit 1
HP_CONFIG="${WORKSPACE_HOST_PROVISION_FILE:-$REPO_ROOT/config/host-provision.yaml}"
HP_STATE_DIR="${WORKSPACE_GUARD_STATE_DIR:-/usr/lib/workspace-guard}"
HP_MARKER="$HP_STATE_DIR/host-provision.ok"

usage() {
    cat <<EOF
Usage: $0 [--dry-run] [--preflight] [--phase N] [--skip-phase5]
       [--acknowledge-direct-root-agent]
Root-only host bootstrap: admin, fleet sudo audit, identities, guard stack.
Fleet sudo is never modified (RED=sudo, YELLOW=no sudo).
Config: config/host-provision.yaml (copy from .example)
Make: sudo make provision-host | sudo make install-host-stack
EOF
}

DRY_RUN=0
PREFLIGHT=0
PHASE_ONLY=""
SKIP_PHASE5=0
ACK_DIRECT_ROOT=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run|-n) DRY_RUN=1; shift ;;
        --preflight) PREFLIGHT=1; shift ;;
        --phase) PHASE_ONLY="${2:?}"; shift 2 ;;
        --skip-phase5) SKIP_PHASE5=1; shift ;;
        --acknowledge-direct-root-agent) ACK_DIRECT_ROOT=1; shift ;;
        --demote-fleet-sudo)
            echo "ERROR: --demote-fleet-sudo removed (fleet sudo is never modified)" >&2
            exit 2
            ;;
        --best-effort-phase5)
            echo "ERROR: --best-effort-phase5 removed (phase 5 fails closed on any error)" >&2
            exit 2
            ;;
        -h|--help) usage; exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

if [[ "$(id -u)" != "0" ]]; then
    echo "ERROR: provision-host needs root" >&2
    exit 2
fi

export HP_CONFIG HP_REPO_ROOT="$REPO_ROOT" HP_STATE_DIR
# shellcheck source=scripts/lib/host-provision-parse.sh
source "$LIB_DIR/host-provision-parse.sh" || exit 1

if [[ ! -f "$HP_CONFIG" ]]; then
    hp_config_error_missing_host_provision "$HP_CONFIG" || exit 2
fi
# shellcheck source=scripts/lib/host-provision-users.sh
source "$LIB_DIR/host-provision-users.sh" || exit 1
# shellcheck source=scripts/lib/host-provision-admin.sh
source "$LIB_DIR/host-provision-admin.sh" || exit 1
# shellcheck source=scripts/lib/host-provision-sudo.sh
source "$LIB_DIR/host-provision-sudo.sh" || exit 1
# shellcheck source=scripts/lib/host-provision-operator.sh
source "$LIB_DIR/host-provision-operator.sh" || exit 1

hp_should_run_phase() {
    local n="$1"
    [[ -z "$PHASE_ONLY" || "$PHASE_ONLY" == "$n" ]]
}

hp_write_marker() {
    local admin="$1" fleet_sha="$2" um="$3"
    mkdir -p "$HP_STATE_DIR"
    {
        echo "admin=$admin"
        echo "fleet_sha256=$fleet_sha"
        echo "completed_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        echo "user_management=$um"
    } > "$HP_MARKER"
    chmod 0644 "$HP_MARKER"
}

hp_run_preflight() {
    local fleet_user token_path
    echo "==> Host provision preflight (read-only)"
    echo "    config: $HP_CONFIG"
    echo "    admin.name: $ADMIN_NAME"
    if [[ "$USER_MGMT" -eq 1 ]]; then
        echo "    user_management.enabled: true"
    else
        echo "    user_management.enabled: false"
    fi
    if hp_admin_exists "$ADMIN_NAME"; then
        echo "    admin account: present"
    else
        echo "    admin account: MISSING"
    fi
    if hp_admin_has_sudo "$ADMIN_NAME"; then
        echo "    admin sudo: ready (group or managed drop-in)"
    else
        echo "    admin sudo: not ready"
    fi
    token_path="$(hp_phase2_token_path)"
    if [[ -f "$token_path" ]]; then
        echo "    phase-2 token: present ($token_path)"
    else
        echo "    phase-2 token: absent (phase 3 will refuse until phase 2 passes)"
    fi
    if [[ -f "$FLEET_FILE" ]]; then
        echo "    fleet file: present ($FLEET_FILE)"
        while IFS= read -r fleet_user; do
            [[ -z "$fleet_user" ]] && continue
            hp_sudo_preflight_fleet_user "$fleet_user"
        done < <(hp_users_list_fleet_names "$FLEET_FILE")
    elif [[ "$USER_MGMT" -eq 1 ]]; then
        echo "    fleet file: MISSING ($FLEET_FILE)"
        hp_config_error_missing_fleet_file "$FLEET_FILE" "preflight (user_management enabled)"
        return 1
    else
        echo "    fleet file: optional (user_management disabled)"
    fi
    if [[ -n "${WORKSPACE_ADMIN_PASSWORD:-}" ]]; then
        echo "    WORKSPACE_ADMIN_PASSWORD: set (phase 2 will use it)"
    else
        echo "    WORKSPACE_ADMIN_PASSWORD: unset (phase 2 will prompt)"
    fi
}

ADMIN_NAME="$(hp_admin_name)"
[[ -z "$ADMIN_NAME" ]] && ADMIN_NAME="admin"
ADMIN_SHELL="$(hp_parse_field admin.shell)"
[[ -z "$ADMIN_SHELL" ]] && ADMIN_SHELL="/bin/bash"
ADMIN_CREATE_HOME="$(hp_parse_field admin.create_home)"
[[ -z "$ADMIN_CREATE_HOME" ]] && ADMIN_CREATE_HOME="true"
FLEET_FILE="$(hp_fleet_users_file)"
FLEET_SHA=""
if [[ -f "$FLEET_FILE" ]]; then
    FLEET_SHA="$(hp_users_fleet_sha256 "$FLEET_FILE")"
fi
USER_MGMT=0
if hp_user_mgmt_enabled; then USER_MGMT=1; fi

if [[ "$PREFLIGHT" -eq 1 ]]; then
    hp_run_preflight || exit 1
    exit 0
fi

if [[ "$USER_MGMT" -eq 1 ]]; then
    hp_config_require_fleet_file "$FLEET_FILE" 1 "before host provision phases" || exit 1
    if [[ "$DRY_RUN" -eq 0 ]]; then
        hp_operator_mandatory_fleet_report "$FLEET_FILE" "$ADMIN_NAME"
    fi
fi

# Fresh full run or phase 1: drop stale phase-2 token so old tokens cannot authorize phase 3 alone.
if [[ -z "$PHASE_ONLY" || "$PHASE_ONLY" == "1" ]]; then
    hp_phase2_token_clear
fi

ADMIN_NEW=0
ADMIN_PASSWORD=""

# --- Phase 1: admin break-glass ---
if hp_should_run_phase 1 && [[ "$USER_MGMT" -eq 1 ]]; then
    echo "==> Phase 1: admin break-glass ($ADMIN_NAME)"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "  DRY-RUN: would ensure admin $ADMIN_NAME with managed sudoers"
    else
        if ! hp_admin_exists "$ADMIN_NAME"; then
            hp_admin_create_account "$ADMIN_NAME" "$ADMIN_SHELL" "$ADMIN_CREATE_HOME"
            ADMIN_NEW=1
        fi
        if [[ "$ADMIN_NEW" -eq 1 ]] || ! hp_admin_has_sudo "$ADMIN_NAME"; then
            if [[ "$ADMIN_NEW" -eq 1 ]]; then
                if [[ -n "${WORKSPACE_ADMIN_PASSWORD:-}" ]]; then
                    ADMIN_PASSWORD="$WORKSPACE_ADMIN_PASSWORD"
                else
                    ADMIN_PASSWORD="$(hp_admin_generate_password)"
                fi
                hp_admin_set_password "$ADMIN_NAME" "$ADMIN_PASSWORD"
                hp_admin_print_password_banner "$ADMIN_NAME" "$ADMIN_PASSWORD"
            fi
            hp_admin_install_sudoers_dropin "$ADMIN_NAME"
            echo "  Installed $HP_SUDOERS_ADMIN"
        else
            echo "  OK: admin $ADMIN_NAME already exists with managed sudo (unchanged)"
            echo "  NOTE: re-run still requires phase 2 (existing admin password)"
        fi
        hp_admin_assert_sudo_ready "$ADMIN_NAME"
    fi
fi

# --- Phase 2: password gate ---
if hp_should_run_phase 2 && [[ "$USER_MGMT" -eq 1 ]]; then
    echo "==> Phase 2: admin password gate"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "  DRY-RUN: would verify admin password"
    else
        if ! hp_admin_exists "$ADMIN_NAME"; then
            echo "ERROR: phase 2 refused: admin $ADMIN_NAME does not exist (run phase 1 first)" >&2
            exit 1
        fi
        entered="$(hp_admin_resolve_phase2_password "$ADMIN_NAME" "Enter password for $ADMIN_NAME: ")" || exit 1
        if ! hp_admin_verify_password "$ADMIN_NAME" "$entered"; then
            echo "ERROR: admin password verification failed" >&2
            exit 1
        fi
        hp_phase2_token_write "$ADMIN_NAME"
        echo "  PASS: admin password verified"
    fi
fi

# --- Phase 3: fleet hardening ---
if hp_should_run_phase 3 && [[ "$USER_MGMT" -eq 1 ]]; then
    echo "==> Phase 3: fleet user accounts (audit only - sudo never modified)"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "  DRY-RUN: would ensure fleet users and print sudo audit"
    else
        hp_phase2_token_consume "$ADMIN_NAME"
        hp_admin_assert_sudo_ready "$ADMIN_NAME"
        hp_config_require_fleet_file "$FLEET_FILE" 1 "phase 3 fleet accounts" || exit 1
        hp_operator_gate_direct_root_before_phase3 "$FLEET_FILE" "$ADMIN_NAME" "$ACK_DIRECT_ROOT"
        hp_users_ensure_fleet_accounts "$FLEET_FILE"
        local_user=""
        while IFS= read -r local_user; do
            [[ -z "$local_user" ]] && continue
            [[ "$local_user" == "$ADMIN_NAME" ]] && continue
            hp_operator_phase3_fleet_line "$local_user"
        done < <(hp_users_list_fleet_names "$FLEET_FILE")
    fi
fi

# --- Phase 4: git / SSH identity ---
if hp_should_run_phase 4; then
    echo "==> Phase 4: git / SSH identity"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "  DRY-RUN: would provision identities and install-home-lock"
    else
        if [[ "$USER_MGMT" -eq 1 ]]; then
            hp_config_require_fleet_file "$FLEET_FILE" 1 "phase 4 git/SSH identity" || exit 1
            bash "$SCRIPT_DIR/provision-user-git-identity" \
                --admin-from "$HP_CONFIG" --users-file "$FLEET_FILE"
        else
            bash "$SCRIPT_DIR/provision-user-git-identity" \
                --admin-from "$HP_CONFIG" --users-file /dev/null
        fi
        bash "$SCRIPT_DIR/install-home-lock"
    fi
fi

# --- Phase 5: guard stack ---
if hp_should_run_phase 5 && [[ "$SKIP_PHASE5" -eq 0 ]]; then
    echo "==> Phase 5: guard stack"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "  DRY-RUN: would build/install guard stack"
    else
        if [[ ! -f "$REPO_ROOT/config/agent-git-identity" ]] \
            && [[ -f "$REPO_ROOT/config/agent-git-identity.example" ]]; then
            cp "$REPO_ROOT/config/agent-git-identity.example" "$REPO_ROOT/config/agent-git-identity"
        fi
        install_lock="$(hp_parse_field guard_stack.install_lock)"
        install_auditd="$(hp_parse_field guard_stack.install_auditd)"
        GUARD_PROVISION_CONTEXT=1 \
            INSTALL_LOCK="${install_lock:-false}" INSTALL_AUDITD="${install_auditd:-false}" \
            make -C "$REPO_ROOT" install-host-stack-phase5
        if [[ "$USER_MGMT" -eq 1 ]]; then
            hp_install_system_config "$HP_CONFIG"
            hp_write_marker "$ADMIN_NAME" "$FLEET_SHA" "true"
            hp_operator_print_completion_banner "$FLEET_FILE" "$ADMIN_NAME"
        fi
        echo "==> Host provision complete"
        [[ -f "$HP_MARKER" ]] && echo "    marker: $HP_MARKER"
    fi
fi

echo "------------------------------------------------------------"
if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "(dry-run: no system changes)"
fi