#!/usr/bin/env bash
# home-drift-check: read-only drift check for the home lock surface.
#
# Implements docs/specifications/SPEC-HOME-LOCK.md section 4.4.
# For every entry recorded by install-home-lock in res/home-lock-
# state.yaml this script verifies the file still exists, is still
# owned by root:root, and still has the recorded mode. Report only:
# no auto-repair is performed so a forensics audit trail is preserved.
#
# Usage:
#   scripts/home-drift-check             # check + write res/home-drift-report.yaml
#   scripts/home-drift-check --quiet     # stdout only on CRITICAL
#   scripts/home-drift-check --help
#
# Exit codes:
#   0  no CRITICAL drift
#   1  CRITICAL drift detected
#   2  baseline state file missing (run make install-home-lock first)
#
# Drift classes:
#   missing-file        : path vanished (suspected tamper)
#   owner-changed       : no longer root:root (lock bypassed)
#   mode-changed        : mode differs from locked value
# Each row carries a class field written to res/home-drift-report.yaml.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RES_DIR="$REPO_ROOT/res"
STATE_FILE="$RES_DIR/home-lock-state.yaml"
DRIFT_REPORT="$RES_DIR/home-drift-report.yaml"

DEVNULL=/dev/null

QUIET=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --quiet|-q) QUIET=1; shift ;;
        -h|--help)
            cat <<EOF
Usage: $0 [--quiet]
Compare live home-lock surface against res/home-lock-state.yaml.
Report only; no auto-repair (preserves audit trail).
Exit: 0 no critical drift, 1 critical drift, 2 baseline missing.
EOF
            exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

if [[ ! -f "$STATE_FILE" ]]; then
    echo "ERROR: baseline missing: $STATE_FILE" >&2
    echo "       run: make install-home-lock" >&2
    exit 2
fi

entries_tmp="$(mktemp -t home-drift-entries.XXXXXX)"
trap 'rm -f "$entries_tmp"' EXIT
awk '
    /^  - path: *"/ {
        if (p) printf "%s\t%s\n", p, emode
        v=$0; sub(/^.*path: *"/,"",v); sub(/".*$/,"",v); p=v
        emode="?"
    }
    /^    expected_mode: *"/ { v=$0; sub(/^.*mode: *"/,"",v); sub(/".*$/,"",v); emode=v }
    END { if (p) printf "%s\t%s\n", p, emode }
' "$STATE_FILE" | sort -u > "$entries_tmp"

total="$(wc -l < "$entries_tmp")"
if [[ "$total" -eq 0 ]]; then
    echo "NOTICE: state file has no recorded entries; nothing to check"
    : > "$DRIFT_REPORT"
    echo "# Auto-generated by scripts/home-drift-check on $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$DRIFT_REPORT"
    echo "drift:" >> "$DRIFT_REPORT"
    echo "summary:" >> "$DRIFT_REPORT"
    echo "  critical: 0" >> "$DRIFT_REPORT"
    echo "  checked_at: $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$DRIFT_REPORT"
    exit 0
fi

CRITICAL=0
WARNINGS=0
NOW="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
log() { printf '%s\n' "$1"; }
gather() { printf '  - {path: "%s", class: "%s", detail: "%s", timestamp: "%s"}\n' "$1" "$2" "$3" "$NOW" >> "$DRIFT_REPORT"; }

: > "$DRIFT_REPORT"
{
    echo "# Auto-generated by scripts/home-drift-check on $NOW"
    echo "# Baseline snapshot: res/home-lock-state.yaml"
    echo "drift:"
} >> "$DRIFT_REPORT"

while IFS=$'\t' read -r path emode; do
    [[ -z "$path" ]] && continue
    if [[ ! -e "$path" ]]; then
        cls="CRITICAL"; CRITICAL=$((CRITICAL+1))
        msg="CRITICAL: $path vanished (suspected tamper)"
        [[ "$QUIET" -ne 1 ]] && log "$msg"; gather "$path" "missing-file" "$cls" "no-file"
        continue
    fi
    cur_uid="$(stat -c '%u' "$path" 2>"$DEVNULL")" || cur_uid="?"
    cur_gid="$(stat -c '%g' "$path" 2>"$DEVNULL")" || cur_gid="?"
    cur_mode="$(stat -c '%a' "$path" 2>"$DEVNULL")" || cur_mode="?"
    if [[ "$cur_uid" != "0" || "$cur_gid" != "0" ]]; then
        cls="CRITICAL"; CRITICAL=$((CRITICAL+1))
        msg="CRITICAL: $path no longer root:root (uid=$cur_uid gid=$cur_gid)"
        log "$msg"; gather "$path" "owner-changed" "$cls" "uid=$cur_uid gid=$cur_gid"
    fi
    if [[ "$emode" != "?" && "$cur_mode" != "?" && "$cur_mode" != "$emode" ]]; then
        cls="CRITICAL"; CRITICAL=$((CRITICAL+1))
        msg="CRITICAL: $path mode $cur_mode (expected $emode)"
        log "$msg"; gather "$path" "mode-changed" "$cls" "expected=$emode actual=$cur_mode"
    fi
done < "$entries_tmp"

{
    echo ""
    echo "summary:"
    echo "  critical: $CRITICAL"
    echo "  warnings: $WARNINGS"
    echo "  checked_at: $NOW"
} >> "$DRIFT_REPORT"

if [[ "$QUIET" -ne 1 ]]; then
    echo "------------------------------------------------------------"
    echo "Home drift check: $CRITICAL critical, $WARNINGS warnings"
    echo "Report:           $DRIFT_REPORT"
fi

if [[ "$CRITICAL" -gt 0 ]]; then
    exit 1
fi
exit 0