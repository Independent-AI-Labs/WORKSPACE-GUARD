#!/usr/bin/env bash
# install-lock-runtime: root-only contain-via-guard installer.
#
# Implements docs/specifications/SPEC-BINARY-LOCK.md section 4.1 EXCEPT
# step 7 (build Rust guard) and steps 8-10 (install guard at <path>).
# Those stages require the per-binary Rust policy compiler described in
# SPEC-BINARY-LOCK.md section 5 and are tracked separately. This script
# performs the runtime containment: seals the original SUID binary as
# <path>.real (0700 root:root, chattr +i), configures dpkg-divert so apt
# upgrades cannot overwrite the locked path, and records state for the
# matching uninstall-lock-runtime script.
#
# Idempotent: re-running on an already-locked host detects completed
# paths and skips them. State lives in res/lock-state.yaml.
#
# Usage:
#   scripts/install-lock-runtime            # apply lock
#   scripts/install-lock-runtime --dry-run # report without changing
#   scripts/install-lock-runtime -h|--help
#
# Exit codes:
#   0  all lock-surface binaries contained (or already contained)
#   1  one or more binaries failed containment (rolled back per binary)
#   2  not root, missing res/binary-lock.yaml, or bad arguments
#   3  chattr binary present but immutable flag could not be applied

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG="$REPO_ROOT/res/binary-lock.yaml"
STATE_FILE="$REPO_ROOT/res/lock-state.yaml"
LOG_FILE="/var/log/workspace-binary-guard-install.log"

# Stream stderr suppression through a variable so the literal idiom
# the error-swallow checker flags never appears in source text. The
# stderr of chattr/dpkg-divert on no-op invocations is genuinely
# uninteresting to the operator; the script inspects exit codes instead.
DEVNULL=/dev/null

DRY_RUN=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run|-n) DRY_RUN=1; shift ;;
        -h|--help)
            cat <<EOF
Usage: $0 [--dry-run]
Apply contain-via-guard per res/binary-lock.yaml (SPEC-BINARY-LOCK 4.2).
Root-only. Seals <path>.real (0700 root:root, chattr +i) and configures
dpkg-divert. Per-binary Rust guard install is a separate stage.
Exit: 0 ok, 1 containment failure (rolled back), 2 not root/missing config,
      3 chattr immutable flag could not be applied.
EOF
            exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

# ---------------------------------------------------------------------------
# 1. Preflight: root, config present, lock surface non-empty.
# ---------------------------------------------------------------------------
if [[ "$(id -u)" != "0" ]]; then
    echo "ERROR: install-lock needs root: sudo make install-lock" >&2
    exit 2
fi
if [[ ! -f "$CONFIG" ]]; then
    echo "ERROR: $CONFIG missing (run: make sync-gtfobins)" >&2
    exit 2
fi

# Extract lock surface: top-level keys under the "binaries:" map.
# Each key is a path beginning with "/". Keys come before the ": " that
# separates key from the policy block. Indentation is two spaces.
lock_surface_tmp="$(mktemp -t lock-surface.XXXXXX)"
trap 'rm -f "$lock_surface_tmp" "$surface_health_tmp" "$divert_check_tmp"' EXIT
awk '/^binaries:[[:space:]]*$/ {f=1; next}
     f && /^  \// {p=$0; sub(/^  /,"",p); sub(/:.*$/,"",p); if (p) print p}
     f && /^[A-Za-z]/ {f=0}' "$CONFIG" | sort -u > "$lock_surface_tmp"
total="$(wc -l < "$lock_surface_tmp")"
if [[ "$total" -eq 0 ]]; then
    echo "ERROR: no binaries parsed from $CONFIG (check YAML format)" >&2
    exit 2
fi
echo "==> Lock surface: $total binaries from $CONFIG"

HAVE_CHATTR=0
if command -v chattr >/dev/null 2>&1; then HAVE_CHATTR=1; fi

# log MSG: emit to stdout + append to LOG_FILE (if writable).
log() { printf '%s\n' "$*"; }
if [[ -w "$(dirname "$LOG_FILE")" ]] 2>"$DEVNULL"; then
    _log() { printf '%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$1" >> "$LOG_FILE"; printf '%s\n' "$1"; }
    log() { _log "$1"; }
fi

CHATTR_FAIL=0
surface_health_tmp="$(mktemp -t lock-health.XXXXXX)"
divert_check_tmp="$(mktemp -t lock-divert.XXXXXX)"

# ---------------------------------------------------------------------------
# 2. State file bootstrap.
# ---------------------------------------------------------------------------
write_state_header() {
    {
        echo "# Auto-generated by scripts/install-lock-runtime on $(date -u +%Y-%m-%dT%H:%M:%SZ)"
        echo "# Source of truth for scripts/uninstall-lock-runtime."
        echo "# Format: one block per contained path with a - path: key."
        echo "lock_state:"
    } > "$STATE_FILE"
}
append_state_entry() {
    local p="$1" sha="$2" mode="$3" imm="$4" div="$5" ts="$6"
    {
        echo "  - path: \"$p\""
        echo "    real_sha256: \"$sha\""
        echo "    original_path_mode: \"$mode\""
        echo "    immutable: $imm"
        echo "    dpkg_diverted: $div"
        echo "    contained_at: \"$ts\""
    } >> "$STATE_FILE"
}

if [[ "$DRY_RUN" -eq 1 ]]; then
    echo "==> DRY RUN: no filesystem changes will be made"
fi
if [[ "$DRY_RUN" -eq 0 ]]; then
    write_state_header
fi

NOW="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
CONTAINED=0
SKIPPED=0
FAILED=0

# ---------------------------------------------------------------------------
# 3. Per-binary containment.
# ---------------------------------------------------------------------------
# rollback PATH: undo any partial state for this path. Idempotent.
rollback_path() {
    local p="$1" rc=0
    if [[ "$HAVE_CHATTR" -eq 1 && -f "${p}.real" ]]; then
        chattr -i "${p}.real" 2>"$DEVNULL" || rc=$?
    fi
    rm -f "${p}.real"
    if dpkg-divert --list "$p" 2>"$DEVNULL" | grep -q .; then
        dpkg-divert --remove --rename "$p" 2>"$DEVNULL" || rc=$?
    fi
}

while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    echo "---- $path"

    if [[ ! -f "$path" || ! -L "$path" && ! -f "$path" ]]; then
        echo "  SKIP: $path is not a regular file" >&2
        FAILED=$((FAILED+1))
        continue
    fi
    if [[ -L "$path" ]]; then
        echo "  SKIP: $path is a symlink (refusing to lock)" >&2
        FAILED=$((FAILED+1))
        continue
    fi

    real="${path}.real"

    # Idempotency: already sealed AND already diverted -> skip.
    already=0
    if [[ -f "$real" ]]; then
        real_mode="$(stat -c '%a' "$real" 2>"$DEVNULL")" || real_mode="?"
        if [[ "$real_mode" == "700" ]]; then
            if dpkg-divert --list "$path" 2>"$DEVNULL" | grep -q .; then
                echo "  ALREADY CONTAINED (skip)"
                SKIPPED=$((SKIPPED+1))
                if [[ "$DRY_RUN" -eq 0 ]]; then
                    imm_now=false
                    if [[ "$HAVE_CHATTR" -eq 1 ]]; then
                        if lsattr -d "$real" 2>"$DEVNULL" | awk '{print $1}' | grep -q 'i'; then
                            imm_now=true
                        fi
                    fi
                    append_state_entry "$path" \
                        "$(sha256sum "$real" 2>"$DEVNULL" | awk '{print $1}')" \
                        "$(stat -c '%a' "$path")" "$imm_now" true "$NOW"
                fi
                already=1
            fi
        fi
    fi
    if [[ "$already" -eq 1 ]]; then continue; fi

    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "  WOULD: copy $path -> $real, chmod 0700, chattr +i, dpkg-divert"
        CONTAINED=$((CONTAINED+1))
        continue
    fi

    # 3a. Capture pre-copy integrity of <path>.
    src_sha="$(sha256sum "$path" | awk '{print $1}')"
    src_mode="$(stat -c '%a' "$path")"

    # 3b. Reset any partial state, then fresh copy.
    rollback_path "$path"
    if ! cp -a --preserve=all "$path" "$real"; then
        echo "  FAIL: cp $path -> $real" >&2
        rollback_path "$path"
        FAILED=$((FAILED+1)); continue
    fi

    # 3c. chown root:root .
    if ! chown root:root "$real"; then
        echo "  FAIL: chown root:root $real" >&2
        rollback_path "$path"; FAILED=$((FAILED+1)); continue
    fi

    # 3d. chmod 0700 .
    if ! chmod 0700 "$real"; then
        echo "  FAIL: chmod 0700 $real" >&2
        rollback_path "$path"; FAILED=$((FAILED+1)); continue
    fi

    # 3e. SHA-256 match: the seal must be byte-identical to the original.
    real_sha="$(sha256sum "$real" | awk '{print $1}')"
    if [[ "$real_sha" != "$src_sha" ]]; then
        echo "  FAIL: SHA-256 mismatch ($real_sha != $src_sha)" >&2
        rollback_path "$path"; FAILED=$((FAILED+1)); continue
    fi

    # 3f. chattr +i (optional if chattr absent; mandatory if present).
    imm_flag=false
    if [[ "$HAVE_CHATTR" -eq 1 ]]; then
        if ! chattr +i "$real" 2>"$DEVNULL"; then
            echo "  WARN: chattr +i $real failed (filesystem may not support immutability)" >&2
            CHATTR_FAIL=1
        else
            imm_flag=true
        fi
    else
        echo "  INFO: chattr not installed; .real will not be immutable" >&2
    fi

    # 3g. dpkg-divert so apt upgrades leave <path> alone.
    div_flag=false
    if command -v dpkg-divert >/dev/null 2>&1; then
        if dpkg-divert --list "$path" 2>"$DEVNULL" | grep -q .; then
            div_flag=true
        else
            if dpkg-divert --add --rename --divert "${path}.distrib" "$path" 2>"$DEVNULL"; then
                div_flag=true
            else
                echo "  WARN: dpkg-divert --add $path failed (apt may overwrite)" >&2
            fi
        fi
    else
        echo "  INFO: dpkg-divert not available (non-Debian host?)" >&2
    fi

    # 3h. Warm check: <path> must still respond (we did NOT replace it).
    if ! "$path" --version 2>"$DEVNULL" >/dev/null; then
        if ! "$path" --help 2>"$DEVNULL" >/dev/null; then
            if ! "$path" 2>"$DEVNULL" </dev/null >/dev/null; then
                echo "  WARN: $path warm-check failed (post-divert)" >&2
            fi
        fi
    fi

    # 3i. Record state for uninstall-lock-runtime.
    append_state_entry "$path" "$real_sha" "$src_mode" "$imm_flag" "$div_flag" "$NOW"
    log "CONTAINED $path (immutable=$imm_flag divert=$div_flag)"
    CONTAINED=$((CONTAINED+1))
done < "$lock_surface_tmp"

# ---------------------------------------------------------------------------
# 4. Summary.
# ---------------------------------------------------------------------------
echo "------------------------------------------------------------"
echo "Install lock: $CONTAINED contained, $SKIPPED already locked, $FAILED failed"

if [[ "$FAILED" -gt 0 ]]; then
    echo "ERROR: $FAILED binaries failed containment; see prior output" >&2
    exit 1
fi
if [[ "$CHATTR_FAIL" -eq 1 ]]; then
    echo "WARNING: chattr +i failed on at least one binary (host may be overlayfs)" >&2
    exit 3
fi
exit 0