#!/usr/bin/env bash
# suid-drift-check: compare the live SUID/CAP surface against the
# committed res/suid-baseline.yaml and res/fcap-baseline.yaml and
# report drift. Also verifies the immutable flag on every *.real file.
#
# Usage:
#   scripts/suid-drift-check             # check + write res/drift-report.yaml
#   scripts/suid-drift-check --quiet     # stdout only on CRITICAL/WARNING
#   scripts/suid-drift-check --help
#
# Exit codes (SPEC-AUDIT.md section 4.4):
#   0  no CRITICAL drift (warnings/info allowed)
#   1  CRITICAL drift detected
#   2  baseline file(s) missing (run make sync-gtfobins first)
#
# Drift classes (SPEC-AUDIT.md section 4.2):
#   new-suid / removed-suid / new-cap / removed-cap / changed-cap /
#   immutable-flag-removed / mode-change-real.
# Each drift row carries a class field written to res/drift-report.yaml.
#
# This script is read-only and does not require root.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RES_DIR="$REPO_ROOT/res"
SUID_BASELINE="$RES_DIR/suid-baseline.yaml"
FCAP_BASELINE="$RES_DIR/fcap-baseline.yaml"
DRIFT_REPORT="$RES_DIR/drift-report.yaml"

# Canonical helpers sourced from scripts/lib/. See scripts/lib/qc.sh
# for the DEVNULL + qc rationale (avoid the literal suppress-stderr
# idiom that the error-swallow checker flags).
source "$SCRIPT_DIR/lib/qc.sh"         || exit 1
source "$SCRIPT_DIR/lib/find-suid.sh"  || exit 1
source "$SCRIPT_DIR/lib/decode-caps.sh" || exit 1

# Single trap at top level: cleanup accumulates every temp file as it
# is created. Replacing the trap per-step was a brittle pattern that
# leaked temps on mid-script abort. Tests/shell/12-regression-bugs.bats
# pins the old buggy behavior so any future regression is caught.
_TEMP_FILES=()
register_temp() {
    _TEMP_FILES+=("$1")
}
cleanup_temps() {
    local f rc
    for f in "${_TEMP_FILES[@]+"${_TEMP_FILES[@]}"}"; do
        rm -f "$f" 2>"$DEVNULL"
        rc=$?
    done
}
trap cleanup_temps EXIT

QUIET=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --quiet|-q) QUIET=1; shift ;;
        -h|--help)
            cat <<EOF
Usage: $0 [--quiet]
Compare live SUID/CAP surface against res/ baselines and report drift.
Exit: 0 no critical drift, 1 critical drift, 2 baseline missing.
EOF
            exit 0 ;;
        *) echo "Unknown arg: $1" >&2; exit 2 ;;
    esac
done

# ---------------------------------------------------------------------------
# 1. Verify baselines. Missing baseline -> exit 2 (SPEC-AUDIT 4.4).
# ---------------------------------------------------------------------------
if [[ ! -f "$SUID_BASELINE" ]]; then
    echo "ERROR: baseline missing: $SUID_BASELINE" >&2
    echo "       run: make sync-gtfobins" >&2
    exit 2
fi
if [[ ! -f "$FCAP_BASELINE" ]]; then
    echo "ERROR: baseline missing: $FCAP_BASELINE" >&2
    echo "       run: make sync-gtfobins" >&2
    exit 2
fi

# ---------------------------------------------------------------------------
# 2. Load known SUID paths and known CAP paths from baselines.
#    suid-baseline.yaml rows look like:   - path: "/usr/bin/sudo"
#    fcap-baseline.yaml rows look like:   - path: "/usr/bin/git"
# ---------------------------------------------------------------------------
known_suid_tmp="$(mktemp)"; register_temp "$known_suid_tmp"
known_fcap_tmp="$(mktemp)"; register_temp "$known_fcap_tmp"

awk '/^  - path:/ {
    v=$0; sub(/^.*path: *"/,"",v); sub(/".*$/,"",v); if (v) print v
}' "$SUID_BASELINE" | sort -u > "$known_suid_tmp"

awk '/^  - path:/ {
    v=$0; sub(/^.*path: *"/,"",v); sub(/".*$/,"",v); if (v) print v
}' "$FCAP_BASELINE" | sort -u > "$known_fcap_tmp"

# ---------------------------------------------------------------------------
# 3. Discover live SUID + CAP surface via scripts/lib/ (shared filter).
# ---------------------------------------------------------------------------
live_suid_tmp="$(mktemp)"; register_temp "$live_suid_tmp"
live_fcap_tmp="$(mktemp)"; register_temp "$live_fcap_tmp"

if ! discover_suid_live "$live_suid_tmp"; then
    echo "WARNING: find returned errors (partial live SUID set)" >&2
fi
if ! discover_caps_live "$live_fcap_tmp"; then
    echo "WARNING: getcap returned errors (partial live CAP set)" >&2
fi

# ---------------------------------------------------------------------------
# 4. Drift classification.
# ---------------------------------------------------------------------------
CRITICAL=0
WARNINGS=0
INFOS=0
NOW="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
log() { printf '%s\n' "$1"; }
gather() { printf '  - {path: "%s", type: "%s", class: "%s", detail: "%s", timestamp: "%s"}\n' "$1" "$2" "$3" "$4" "$NOW" >> "$DRIFT_REPORT"; }

# agent_accessible PATH -> 0/1. /snap is read-only; everything under
# /usr/bin, /usr/local/bin, /usr/sbin, /bin, /sbin is treated as
# agent-accessible (CRITICAL on new cap).
agent_accessible() {
    case "$1" in
        /usr/bin/*|/usr/local/bin/*|/usr/sbin/*|/bin/*|/sbin/*) return 0 ;;
        *) return 1 ;;
    esac
}

# gtfobins_tagged BNAME -> 0/1 by checking the committed baseline's
# gtfobins: true|false field for that path.
gtfobins_for_path() {
    local p="$1" line
    line="$(awk -v p="$p" '
        $0 ~ "^  - path: \""p"\"" { capture=1 }
        capture && /gtfobins: true/  { print "true"; exit }
        capture && /gtfobins: false/ { print "false"; exit }
        capture && /^  - path:/ && $0 !~ "^  - path: \""p"\"" { capture=0 }
    ' "$SUID_BASELINE")"
    [[ "$line" == "true" ]] && return 0 || return 1
}

: > "$DRIFT_REPORT"
{
    echo "# Auto-generated by scripts/suid-drift-check on $NOW"
    echo "# Baseline snapshot: suid-baseline.yaml + fcap-baseline.yaml"
    echo "drift:"
} >> "$DRIFT_REPORT"

# --- 4a. new SUID (live but not in baseline) ---
new_suids_tmp="$(mktemp -t suid-drift-new.XXXXXX)"; register_temp "$new_suids_tmp"
rm_suids_tmp="$(mktemp -t suid-drift-rm.XXXXXX)";   register_temp "$rm_suids_tmp"
comm -13 "$known_suid_tmp" "$live_suid_tmp" > "$new_suids_tmp"
comm -23 "$known_suid_tmp" "$live_suid_tmp" > "$rm_suids_tmp"

while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    local_gtf="false"
    if gtfobins_for_path "$path"; then local_gtf="true"; fi
    if [[ "$local_gtf" == "true" ]]; then
        cls="CRITICAL"; CRITICAL=$((CRITICAL+1))
        msg="CRITICAL: new SUID binary $path (GTFOBins: true)"
    else
        cls="WARNING"; WARNINGS=$((WARNINGS+1))
        msg="WARNING:  new SUID binary $path (not on GTFOBins; check apt history)"
    fi
    [[ "$QUIET" -eq 1 && "$cls" == "WARNING" ]] || log "$msg"
    gather "$path" "new-suid" "$cls" "gtfobins=$local_gtf"
done < "$new_suids_tmp"

# --- 4b. removed SUID (in baseline but not live) ---
while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    msg="WARNING:  removed SUID binary $path (apt upgrade may have overwrote the guard)"
    WARNINGS=$((WARNINGS+1))
    [[ "$QUIET" -eq 1 ]] || log "$msg"
    gather "$path" "removed-suid" "WARNING" "guard-overwrite-suspected"
done < "$rm_suids_tmp"

# --- 4c. file capability drift (new / removed / changed) ---
known_fcap_raw="$(mktemp -t suid-drift-fc-known.XXXXXX)"; register_temp "$known_fcap_raw"
live_fcap_raw="$(mktemp -t suid-drift-fc-live.XXXXXX)";   register_temp "$live_fcap_raw"
# Re-emit baseline caps in the same TAB-separated format the live scan uses.
awk '/^  - path:/ {p=$0; sub(/^.*path: *"/,"",p); sub(/".*$/,"",p)}
     /^    caps:/ {c=$0; sub(/^.*caps: *"/,"",c); sub(/".*$/,"",c); if (p && c) print p "\t" c}' \
     "$FCAP_BASELINE" | sort -u > "$known_fcap_raw"
sort -u "$live_fcap_tmp" > "$live_fcap_raw"

# Compute the three drift classes explicitly by joining on the path key.
new_caps_tmp="$(mktemp -t suid-drift-fc-new.XXXXXX)"; register_temp "$new_caps_tmp"
rm_caps_tmp="$(mktemp -t suid-drift-fc-rm.XXXXXX)";   register_temp "$rm_caps_tmp"
ch_caps_tmp="$(mktemp -t suid-drift-fc-ch.XXXXXX)";   register_temp "$ch_caps_tmp"

while IFS=$'\t' read -r path caps; do
    [[ -z "$path" ]] && continue
    existing="$(awk -v p="$path" -F'\t' '$1==p {print $2; exit}' "$known_fcap_raw")"
    if [[ -z "$existing" ]]; then
        printf '%s\t%s\n' "$path" "$caps" >> "$new_caps_tmp"
    elif [[ "$existing" != "$caps" ]]; then
        printf '%s\t%s\t%s\n' "$path" "$existing" "$caps" >> "$ch_caps_tmp"
    fi
done < "$live_fcap_raw"

while IFS=$'\t' read -r path caps; do
    [[ -z "$path" ]] && continue
    existing="$(awk -v p="$path" -F'\t' '$1==p {print $2; exit}' "$live_fcap_raw")"
    if [[ -z "$existing" ]]; then
        printf '%s\t%s\n' "$path" "$caps" >> "$rm_caps_tmp"
    fi
done < "$known_fcap_raw"

while IFS=$'\t' read -r path caps; do
    [[ -z "$path" ]] && continue
    if agent_accessible "$path"; then
        cls="CRITICAL"; CRITICAL=$((CRITICAL+1))
        msg="CRITICAL: new file capability on agent binary $path ($caps)"
    else
        cls="WARNING"; WARNINGS=$((WARNINGS+1))
        msg="WARNING:  new file capability on $path ($caps)"
    fi
    [[ "$QUIET" -eq 1 && "$cls" == "WARNING" ]] || log "$msg"
    gather "$path" "new-cap" "$cls" "caps=$caps"
done < "$new_caps_tmp"

while IFS=$'\t' read -r path old newc; do
    [[ -z "$path" ]] && continue
    cls="WARNING"; WARNINGS=$((WARNINGS+1))
    msg="WARNING:  file capability changed on $path: '$old' -> '$newc'"
    [[ "$QUIET" -eq 1 ]] || log "$msg"
    gather "$path" "changed-cap" "$cls" "from=$old to=$newc"
done < "$ch_caps_tmp"

while IFS=$'\t' read -r path caps; do
    [[ -z "$path" ]] && continue
    cls="INFO"; INFOS=$((INFOS+1))
    msg="INFO:     file capability removed from $path (was $caps)"
    [[ "$QUIET" -eq 1 ]] || log "$msg"
    gather "$path" "removed-cap" "INFO" "was=$caps"
done < "$rm_caps_tmp"

# --- 4d. immutable-flag check on every contained binary in binary-lock ---
# Only entries with contained: true and a non-null path in
# res/binary-lock.yaml should have a .real file. Checking all baselined
# SUID paths produces false positives for binaries that are tracked but
# not yet contained.
contained_tmp="$(mktemp -t suid-drift-contained.XXXXXX)"; register_temp "$contained_tmp"
BINARY_LOCK="$RES_DIR/binary-lock.yaml"
if [[ -f "$BINARY_LOCK" ]]; then
    awk '/^  - name:/ { name=$0; sub(/^.*name: *"/,"",name); sub(/".*$/,"",name) }
         /^    path:/ { p=$0; sub(/^.*path: *"/,"",p); sub(/".*$/,"",p) }
         /^    contained: true/ { if (p && p != "null") print p }
         /^    contained: false/ { p="" }' "$BINARY_LOCK" > "$contained_tmp"
fi

while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    real="${path}.real"
    if [[ ! -f "$real" ]]; then
        if [[ -f "$path" ]]; then
            cls="CRITICAL"; CRITICAL=$((CRITICAL+1))
            msg="CRITICAL: contained binary $path has no ${path}.real (guard never installed or removed)"
            log "$msg"; gather "$path" "missing-real" "$cls" "no-.real-file"
        fi
        continue
    fi
    attrs="$(qc '' lsattr -d "$real" 2>"$DEVNULL")"
    if [[ ! "$attrs" =~ i ]]; then
        cls="CRITICAL"; CRITICAL=$((CRITICAL+1))
        msg="CRITICAL: immutable flag removed on $real (root can tamper)"
        log "$msg"; gather "$real" "immutable-flag-removed" "$cls" "chattr -i detected"
    fi
    mode="$(qc '?' stat -c '%a' "$real")"
    if [[ "$mode" != "700" && "$mode" != "?" ]]; then
        cls="CRITICAL"; CRITICAL=$((CRITICAL+1))
        msg="CRITICAL: mode on $real is $mode (expected 700 after contain)"
        log "$msg"; gather "$real" "mode-change-real" "$cls" "mode=$mode"
    fi
done < "$contained_tmp"

# ---------------------------------------------------------------------------
# 5. Summary + exit code.
# ---------------------------------------------------------------------------
echo "" >> "$DRIFT_REPORT"
{
    echo "summary:"
    echo "  critical: $CRITICAL"
    echo "  warnings: $WARNINGS"
    echo "  infos:    $INFOS"
    echo "  checked_at: $NOW"
} >> "$DRIFT_REPORT"

if [[ "$QUIET" -ne 1 ]]; then
    echo "------------------------------------------------------------"
    echo "Drift check: $CRITICAL critical, $WARNINGS warnings, $INFOS info"
    echo "Report:      $DRIFT_REPORT"
fi

if [[ "$CRITICAL" -gt 0 ]]; then
    exit 1
fi
exit 0