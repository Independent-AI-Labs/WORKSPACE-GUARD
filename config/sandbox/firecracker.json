{
  "boot-source": {
    "kernel_image_path": "config/sandbox/vmlinux",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off nomodules ro"
  },
  "drives": [{
    "drive_id": "rootfs",
    "path_on_host": "config/sandbox/rootfs.ext4",
    "is_root_device": true,
    "is_read_only": true
  }],
  "machine-config": {
    "vcpu_count": 2,
    "mem_size_mib": 512
  },
  "network-interfaces": []
}