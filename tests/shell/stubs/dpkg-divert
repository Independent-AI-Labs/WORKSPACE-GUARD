#!/usr/bin/env bash
# dpkg-divert stub: mimics the three subcommands install/uninstall-
# lock-runtime rely on. State persists to $GUARD_DIVERT_DB (one path
# per line); absent entries behave as undiverted.
#   dpkg-divert --list <path>            -> stdout line iff diverted
#   dpkg-divert --add --rename --divert <p>.distrib <path>  -> record
#   dpkg-divert --remove --rename <path> -> unrecord
db="${GUARD_DIVERT_DB:-}"
nulldev="${DEVNULL:-/dev/null}"
case "$1" in
    --list)
        path="$2"
        if [ -n "$db" ] && [ -f "$db" ] && grep -qxF -- "$path" "$db" 2>"$nulldev"; then
            printf 'local diversion of %s to %s.distrib\n' "$path" "$path"
        fi
        ;;
    --add)
        # args: --add --rename --divert <p>.distrib <path>
        path="${!#}"
        # Detect --divert target for the rename destination.
        divert="" rename=0
        prev=""
        for a in "$@"; do
            if [ "$prev" = "--divert" ]; then divert="$a"; fi
            [ "$a" = "--rename" ] && rename=1
            prev="$a"
        done
        if [ -n "$db" ]; then
            mkdir -p "$(dirname "$db")"
            if ! grep -qxF -- "$path" "$db" 2>"$nulldev"; then
                printf '%s\n' "$path" >> "$db"
            fi
        fi
        # --rename: move $path to the divert target (default .distrib)
        if [ "$rename" -eq 1 ] && [ -f "$path" ]; then
            dest="${divert:-${path}.distrib}"
            mv "$path" "$dest" 2>"$nulldev" || true
        fi
        ;;
    --remove)
        path="${!#}"
        rename=0
        for a in "$@"; do [ "$a" = "--rename" ] && rename=1; done
        if [ -n "$db" ] && [ -f "$db" ]; then
            tmp="$(mktemp)"
            grep -vxF -- "$path" "$db" > "$tmp" 2>"$nulldev" || rc=$?
            mv "$tmp" "$db"
        fi
        # --rename: restore $(path).distrib back to $path
        if [ "$rename" -eq 1 ] && [ -f "${path}.distrib" ]; then
            mv "${path}.distrib" "$path" 2>"$nulldev" || true
        fi
        ;;
    *)
        echo "dpkg-divert stub: unrecognized args: $*" >&2
        exit 2
        ;;
esac
exit 0